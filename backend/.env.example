# Server
PORT=3001

# AI Provider: "gemini" | "openai" | "claude"
AI_PROVIDER=gemini

# API Keys (provide the key for your chosen provider)
# For Gemini: use comma-separated keys for rotation (get free keys from different Google accounts)
# Example: GEMINI_API_KEY=key1,key2,key3
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Processing Configuration
BATCH_SIZE=25
CONCURRENCY_LIMIT=1
MAX_RETRIES=5
BATCH_DELAY_MS=2000

# CORS
FRONTEND_URL=http://localhost:3000
